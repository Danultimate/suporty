# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=replace-with-a-strong-random-secret
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=supporty
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=supporty

# ── OpenAI (cloud LLM — non-sensitive flows) ──────────────────────────────────
OPENAI_API_KEY=sk-...
CLOUD_LLM_MODEL=gpt-4o

# ── Ollama (local LLM — sensitive flows) ──────────────────────────────────────
# Point to your existing Ollama container/host
OLLAMA_BASE_URL=http://your-ollama-host:11434
LOCAL_LLM_MODEL=mistral

# ── RAG ───────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# ── CRM (leave blank to use stub) ─────────────────────────────────────────────
CRM_API_URL=
CRM_API_KEY=

# ── Freshdesk ─────────────────────────────────────────────────────────────────
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=

# ── Thresholds ─────────────────────────────────────────────────────────────────
ESCALATION_THRESHOLD=0.75
